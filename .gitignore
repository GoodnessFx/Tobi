# ============================================================
# Tobi .gitignore
# ============================================================

# --- Secrets and credentials ---
.env
*.pem
*.key
*.crt

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
*.egg-info/
dist/
build/
*.egg

# --- Runtime data (user-specific, regenerated on startup) ---
data/
*.db
*.sqlite3

# --- Node.js / Next.js ---
Tobi/ui/Tobi-ui/node_modules/
Tobi/ui/Tobi-ui/.next/
Tobi/ui/Tobi-ui/out/

# --- macOS ---
.DS_Store
._*
.Spotlight-V100
.Trashes

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Logs ---
*.log
logs/

# --- Temporary files ---
*.tmp
*.temp
*.bak

# --- Chrome extension build artifacts ---
Tobi/browser_extension/*.crx
Tobi/browser_extension/*.zip

# --- Whisper / ML models (large, downloadable) ---
*.bin
*.onnx
*.pt
*.gguf

# --- Audio temp files ---
*.wav
*.mp3
*.aiff
*.webm
!Tobi/ui/Tobi-ui/public/*.wav

# --- Claude Code local config (skills, rules, agents from plugins) ---
.claude/

# --- Internal planning docs (not for public repo) ---
HANDOFF.md
RESEARCH_Tobi_INSPIRATION.md
*.docx

